# ── Email (Resend) ────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The email address that receives messages from your contact form.
CONTACT_TO_EMAIL=you@example.com

# The "from" address used by Resend. Must be on a domain you've
# verified in Resend (see https://resend.com/domains). For local
# testing you can use the Resend sandbox address below.
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# ── Site metadata ────────────────────────────────────────────────
# Public URL of the deployed site, used for SEO tags, sitemap and
# robots.txt. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://raghu.dev

# Optional: Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Plausible / Vercel Analytics / GA4 measurement id
NEXT_PUBLIC_ANALYTICS_ID=
